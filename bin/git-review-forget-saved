#!/usr/bin/env sh
#
# git-review-forget-saved — discard a review put aside with git review-save.
#
# Deletes review-saved/<branch>, its metadata and its banked-edit refs
# (refs/review-saved-edits/<branch>/). Because a saved review was paused, not
# completed, it also rolls the --delta marker back to your last actual review, the
# same way git review-abort does — so a later --delta does not skip those commits.
#
# clean-review deliberately leaves saved reviews alone (it prunes review/* and
# review-fixes/*, not review-saved/*); this command, paired with review-forget-delta
# for the --delta markers, is how you throw a saved review away.
#
set -eu

prog="git review-forget-saved"

usage() {
	cat <<EOF
usage: $prog (<branch> | --all)

Discard a review saved with git review-save: delete review-saved/<branch>, its
banked edits and its metadata, and roll back the --delta marker it left.

  <branch>   discard the saved review for one source branch
  --all      discard every saved review
EOF
}

die() {
	echo "error: $1" >&2
	exit 1
}

arg=""
all=0
while [ $# -gt 0 ]; do
	case "$1" in
	-h | --h)
		usage
		exit 0
		;;
	--all) all=1 ;;
	-*)
		echo "error: unknown option $1" >&2
		usage >&2
		exit 1
		;;
	*)
		if [ -z "$arg" ]; then
			arg="$1"
		else
			die "unexpected argument $1"
		fi
		;;
	esac
	shift
done

if [ -n "$arg" ] && [ "$all" -eq 1 ]; then
	die "use either <branch> or --all, not both"
fi
if [ -z "$arg" ] && [ "$all" -eq 0 ]; then
	usage >&2
	exit 1
fi

git rev-parse --git-dir >/dev/null 2>&1 || die "not a git repository"

cur="$(git symbolic-ref --quiet --short HEAD || true)"

# forget_one <src>: discard the saved review for one source branch.
forget_one() {
	src="$1"
	saved="review-saved/$src"
	if ! git rev-parse --verify --quiet "refs/heads/$saved" >/dev/null; then
		echo "no saved review for $src" >&2
		return
	fi
	if [ "$saved" = "$cur" ]; then
		echo "skipping $src (its branch is currently checked out)" >&2
		return
	fi

	# Roll the --delta marker back to the last actual review before the metadata
	# disappears with the branch. Local reviews track their marker in a separate
	# config section, matching git review-pr / git review-abort.
	if [ "$(git config "branch.$saved.reviewlocal" || true)" = "1" ]; then
		markerkey="reviewworkflowlocal.$src.reviewed"
	else
		markerkey="reviewworkflow.$src.reviewed"
	fi
	prevreviewed="$(git config "branch.$saved.reviewprevreviewed" || true)"
	if [ -n "$prevreviewed" ]; then
		git config "$markerkey" "$prevreviewed"
	else
		git config --unset "$markerkey" 2>/dev/null || true
	fi

	git for-each-ref --format='%(refname)' "refs/review-saved-edits/$src/" | while read -r ref; do
		git update-ref -d "$ref"
	done
	git branch -D "$saved" >/dev/null

	echo "discarded saved review of $src"
}

if [ "$all" -eq 1 ]; then
	branches="$(git for-each-ref --format='%(refname:short)' refs/heads/review-saved/)"
	[ -n "$branches" ] || {
		echo "no saved reviews"
		exit 0
	}
	printf '%s\n' "$branches" | while read -r b; do
		forget_one "${b#review-saved/}"
	done
else
	forget_one "$arg"
fi
