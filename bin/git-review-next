#!/usr/bin/env sh
#
# git-review-next — advance a commit-by-commit review (started with review-pr --step).
#
# Moving banks the edits you made on the current commit into a ref of its own and
# restores any edits you had previously banked on the commit you move to, so you
# can walk back and forth without losing work. git finish-review replays every
# banked edit onto the PR tip.
#
set -eu

prog="git review-next"

usage() {
	cat <<EOF
usage: $prog

Advance a commit-by-commit review to the next commit. Your edits are remembered;
run git review-prev to go back, or git finish-review when you are done.
EOF
}

case "${1:-}" in
-h | --h)
	usage
	exit 0
	;;
"") ;;
*)
	echo "error: unexpected argument $1" >&2
	usage >&2
	exit 1
	;;
esac

# Locate and load the shared helpers the installers place beside this command.
# $0 may be a symlink (Homebrew and install.sh symlink commands onto PATH) or a
# bare name (PATH lookup), so resolve both before taking our directory.
self="$0"
case "$self" in
*/*) ;;
*) self="$(command -v -- "$self" 2>/dev/null || printf '%s\n' "$self")" ;;
esac
while [ -L "$self" ]; do
	link="$(readlink "$self")"
	case "$link" in
	/*) self="$link" ;;
	*) self="$(dirname "$self")/$link" ;;
	esac
done
# shellcheck source=git-review-lib.sh disable=SC1007
. "$(CDPATH= cd -- "$(dirname -- "$self")" && pwd)/git-review-lib.sh"

load_step_review_meta

if [ "$step" -lt "$count" ]; then
	goto_step "$((step + 1))"
else
	echo "no more commits — run git finish-review"
fi
