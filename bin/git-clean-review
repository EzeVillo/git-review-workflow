#!/usr/bin/env sh
#
# git-clean-review — delete the review/<branch> and review-fixes/<branch> branches.
#
# With no <branch> it deletes all of them. It never deletes the branch you are
# currently on. The recorded last-reviewed tip is kept (so --delta keeps working)
# unless you pass --forget.
#
set -eu

prog="git clean-review"
version="0.0.1"

usage() {
	cat <<EOF
usage: $prog [branch] [--forget]

Delete the review/<branch> and review-fixes/<branch> branches.
With no <branch>, delete all of them.

  --forget         also discard the recorded last-reviewed tip (disables --delta)
  -V, --version    print the version and exit
EOF
}

arg=""
forget=0
while [ $# -gt 0 ]; do
	case "$1" in
	-h | --help)
		usage
		exit 0
		;;
	-V | --version)
		echo "$prog $version"
		exit 0
		;;
	--forget) forget=1 ;;
	-*)
		echo "error: unknown option $1" >&2
		usage >&2
		exit 1
		;;
	*)
		if [ -z "$arg" ]; then
			arg="$1"
		else
			echo "error: unexpected argument $1" >&2
			exit 1
		fi
		;;
	esac
	shift
done

cur="$(git symbolic-ref --quiet --short HEAD || true)"

if [ -n "$arg" ]; then
	list="review/$arg review-fixes/$arg"
else
	list="$(git for-each-ref --format='%(refname:short)' refs/heads/review/ refs/heads/review-fixes/)"
fi

if [ -z "$list" ]; then
	echo "no review branches found" >&2
	exit 0
fi

# Word splitting is intentional: branch names cannot contain whitespace.
# shellcheck disable=SC2086
for b in $list; do
	git rev-parse --verify --quiet "refs/heads/$b" >/dev/null || continue
	if [ "$b" = "$cur" ]; then
		echo "skipping $b (currently checked out)" >&2
		continue
	fi
	git branch -D "$b"
done

# Drop any banked commit-by-commit edit refs.
if [ -n "$arg" ]; then
	editns="refs/review-edits/$arg/"
else
	editns="refs/review-edits/"
fi
git for-each-ref --format='%(refname)' "$editns" | while read -r ref; do
	git update-ref -d "$ref"
done

if [ "$forget" -eq 1 ]; then
	if [ -n "$arg" ]; then
		git config --unset "reviewworkflow.$arg.reviewed" 2>/dev/null || true
	else
		git config --get-regexp '^reviewworkflow\..*\.reviewed$' 2>/dev/null |
			while read -r key _; do
				git config --unset "$key" || true
			done
	fi
fi
