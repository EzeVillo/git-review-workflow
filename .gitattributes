# Shell scripts must keep LF line endings on every platform. On Windows,
# checkout would otherwise convert them to CRLF, which breaks the shebang under
# Git Bash and makes shellcheck fail with SC1017 (literal carriage return).
*.sh    text eol=lf
*.bash  text eol=lf
*.zsh   text eol=lf
*.fish  text eol=lf
*.bats  text eol=lf
bin/*   text eol=lf
install.sh   text eol=lf
uninstall.sh text eol=lf

# shellcheck reads .shellcheckrc as a script and rejects CR (SC1017), so it must
# stay LF on Windows checkouts too.
.shellcheckrc text eol=lf
